# LoveLogicAI holaOS Agent Stack — Environment Variables
# Copy to .env and fill in values before running `docker compose up`

# ── Core LLM ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Trend Arbitrage Agent ─────────────────────────────────────────────────────
MUSASHI_API_KEY=
MUSASHI_API_BASE=https://musashi.bot/api
ARBITRAGE_THRESHOLD=0.05          # 5% spread minimum
ALERT_URGENCY_THRESHOLD=7.0       # 0-10 score, alert when >= this

# ── Social Content Engine ────────────────────────────────────────────────────
FIRECRAWL_API_KEY=
FAL_KEY=
TYPEFULLY_API_KEY=
REPLICATE_API_TOKEN=

# ── Micro-SaaS Factory ──────────────────────────────────────────────────────
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
COINBASE_API_KEY=
SENTRY_DSN=

# ── Checkpointer Backend ─────────────────────────────────────────────────────
# 'memory'   — in-process, lost on restart (local dev)
# 'dynamodb' — persistent across restarts (production)
CHECKPOINT_BACKEND=memory
LANGGRAPH_CHECKPOINT_TABLE=lovelogic-checkpoints

# ── AWS (required when CHECKPOINT_BACKEND=dynamodb) ─────────────────────────
AWS_DEFAULT_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Memory ───────────────────────────────────────────────────────────────────
MEMORY_ROOT=./memory/workspace    # Mounted as Docker volume in production
