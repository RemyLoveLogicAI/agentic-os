FROM python:3.11-slim

WORKDIR /app

# System deps for cron + healthcheck
RUN apt-get update && apt-get install -y --no-install-recommends \
    cron curl \
    && rm -rf /var/lib/apt/lists/*

# Install shared requirements
COPY agents/trend-arbitrage/requirements.txt /tmp/req-trend.txt
COPY agents/social-content-engine/requirements.txt /tmp/req-social.txt
COPY agents/micro-saas-factory/requirements.txt /tmp/req-factory.txt
RUN pip install --no-cache-dir \
    -r /tmp/req-trend.txt \
    -r /tmp/req-social.txt \
    -r /tmp/req-factory.txt

# Copy entire project
COPY . .

# Make packages importable
RUN pip install --no-cache-dir -e .

# Create non-root user and grant ownership of runtime dirs
RUN groupadd --gid 1001 agentuser && \
    useradd --uid 1001 --gid 1001 --no-create-home agentuser && \
    mkdir -p state memory/workspace ops/ledgers && \
    chown -R agentuser:agentuser /app

USER agentuser

HEALTHCHECK --interval=30s --timeout=10s --retries=3 \
    CMD pgrep cron > /dev/null || exit 1

CMD ["sh", "-c", "echo 'No command override — start via docker-compose.' && exit 1"]
